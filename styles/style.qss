#card {
    border: none;
    border-radius: 8px;
    background-color: #377D6A;
}

QPushButton#deleteRecordButton {
    background-color: #DC3545;
    color: white;
    padding: 5px 10px;
    border: none;
    border-radius: 4px;
}

QPushButton#deleteRecordButton:hover {
    background-color: #C82333;
}

QLineEdit#invoiceInput,
QDateEdit#invoiceDateInput {
    font-family: "Comic Sans MS";
}
